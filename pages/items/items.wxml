<!-- 物品管理页面 -->
<wxs module="filters" src="../../utils/filters.wxs"></wxs>
<view class="container">
  <!-- 自定义导航栏 -->
  <custom-navbar title="我的物品" statusBarHeight="{{statusBarHeight}}" navbarHeight="{{navbarHeight}}" />

  <!-- 顶部Tab切换 -->
  <view class="top-tabs">
    <view class="top-tab {{currentTab === 'items' ? 'top-tab-active' : ''}}" bindtap="switchTab" data-tab="items">
      <text class="top-tab-icon">📦</text>
      <text class="top-tab-text">物品管理</text>
      <view class="top-tab-badge" wx:if="{{products.length}}">{{products.length}}</view>
    </view>
    <view class="top-tab {{currentTab === 'tobuy' ? 'top-tab-active' : ''}}" bindtap="switchTab" data-tab="tobuy">
      <text class="top-tab-icon">🛒</text>
      <text class="top-tab-text">待购清单</text>
      <view class="top-tab-badge" wx:if="{{toBuyPending.length}}">{{toBuyPending.length}}</view>
    </view>
  </view>

  <!-- 物品管理内容 -->
  <view class="tab-content" wx:if="{{currentTab === 'items'}}">
    <!-- 统计概览 -->
    <view class="stats-row">
      <view class="stat-mini stat-primary">
        <text class="stat-mini-value">{{products.length}}</text>
        <text class="stat-mini-label">总数</text>
      </view>
      <view class="stat-mini stat-warning">
        <text class="stat-mini-value">{{expiringSoonCount}}</text>
        <text class="stat-mini-label">即将过期</text>
      </view>
      <view class="stat-mini stat-danger">
        <text class="stat-mini-value">{{expiredCount}}</text>
        <text class="stat-mini-label">已过期</text>
      </view>
    </view>

    <!-- 筛选标签 -->
    <scroll-view scroll-x class="filter-scroll" wx:if="{{products.length}}">
      <view class="filter-tabs">
        <view class="filter-tab {{currentFilter === 'all' ? 'filter-tab-active' : ''}}" 
              bindtap="onFilterChange" data-filter="all">全部</view>
        <view class="filter-tab {{currentFilter === 'Food' ? 'filter-tab-active' : ''}}" 
              bindtap="onFilterChange" data-filter="Food">🥖 食物</view>
        <view class="filter-tab {{currentFilter === 'CatFood' ? 'filter-tab-active' : ''}}" 
              bindtap="onFilterChange" data-filter="CatFood">🐱 猫粮</view>
        <view class="filter-tab {{currentFilter === 'Medicine' ? 'filter-tab-active' : ''}}" 
              bindtap="onFilterChange" data-filter="Medicine">💊 药品</view>
      </view>
    </scroll-view>

    <!-- 物品列表 -->
    <view class="section-card">
      <loading-state loading="{{loadingProducts}}" />

      <view class="item-list" wx:if="{{!loadingProducts && filters.getLength(filters.filterProducts(products, currentFilter)) > 0}}">
        <view 
          class="item-card"
          wx:for="{{filters.filterProducts(products, currentFilter)}}" 
          wx:key="id"
          data-id="{{item.id}}"
          data-category="{{item.category}}"
          bindtap="onUpdate"
          bindlongpress="showItemActions"
        >
          <view class="item-emoji">{{item.emoji || '📦'}}</view>
          <view class="item-content">
            <text class="item-name">{{item.name}}</text>
            <view class="item-info">
              <text class="item-location">📍 {{item.location.roomPlacement}}</text>
              <text class="item-date-badge {{item.dateClass}}">{{item.bestByFormatted}}</text>
            </view>
          </view>
          <text class="item-arrow">›</text>
        </view>
      </view>

      <!-- 空状态 -->
      <empty-state
        show="{{!loadingProducts && !products.length}}"
        icon="📭" title="还没有添加物品" text="点击下方按钮，开始记录你的物品"
        buttonText="+ 添加物品" bind:buttontap="goToAddItem"
      />
    </view>
  </view>

  <!-- 待购清单内容 -->
  <view class="tab-content" wx:if="{{currentTab === 'tobuy'}}">
    <view class="section-card">
      <loading-state loading="{{loadingToBuy}}" />

      <!-- 未完成列表 -->
      <view class="item-list" wx:if="{{!loadingToBuy && toBuyPending.length}}">
        <view 
          class="item-card tobuy-item"
          wx:for="{{toBuyPending}}" 
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onUpdateToBuy"
          bindlongpress="showToBuyActions"
        >
          <view class="tobuy-checkbox {{item.completed ? 'tobuy-checkbox-checked' : ''}}" 
                catchtap="toggleToBuyComplete" data-id="{{item.id}}">
            <text wx:if="{{item.completed}}">✓</text>
          </view>
          <view class="item-content">
            <text class="item-name">{{item.name}}</text>
            <view class="item-info">
              <view class="priority-badge priority-{{item.priority <= 3 ? 'high' : item.priority <= 7 ? 'medium' : 'low'}}">
                P{{item.priority}}
              </view>
            </view>
          </view>
          <text class="item-arrow">›</text>
        </view>
      </view>

      <!-- 空状态 -->
      <empty-state
        show="{{!loadingToBuy && !toBuyProducts.length}}"
        icon="🛒" title="购物清单是空的" text="记录需要购买的物品"
        buttonText="+ 添加待购" bind:buttontap="goToAddToBuy"
      />
    </view>

    <!-- 已完成的待购物品 -->
    <view class="section-card completed-section" wx:if="{{toBuyCompleted.length}}">
      <view class="completed-header" bindtap="toggleCompletedList">
        <view class="completed-title-wrap">
          <text class="completed-icon">✅</text>
          <text class="completed-title">已完成 ({{toBuyCompleted.length}})</text>
        </view>
        <view class="completed-actions">
          <view class="clear-btn" catchtap="clearCompletedToBuy">清除</view>
          <text class="expand-icon {{showCompleted ? 'expand-icon-up' : ''}}">›</text>
        </view>
      </view>
      
      <view class="completed-list {{showCompleted ? 'completed-list-show' : ''}}">
        <view 
          class="item-card tobuy-item item-card-completed"
          wx:for="{{toBuyCompleted}}" 
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onUpdateToBuy"
          bindlongpress="showToBuyActions"
        >
          <view class="tobuy-checkbox tobuy-checkbox-checked" 
                catchtap="toggleToBuyComplete" data-id="{{item.id}}">
            <text>✓</text>
          </view>
          <view class="item-content item-completed">
            <text class="item-name">{{item.name}}</text>
          </view>
          <text class="item-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 悬浮添加按钮 -->
  <view class="fab-btn" bindtap="{{currentTab === 'items' ? 'goToAddItem' : 'goToAddToBuy'}}">
    <text class="fab-icon">+</text>
  </view>

  <!-- 底部消息推送入口 -->
  <footer-link />

  <!-- 底部安全区 -->
  <view class="safe-bottom"></view>
</view>

<!-- 操作菜单 -->
<action-sheet
  show="{{showActionSheet}}" title="{{actionSheetTitle}}"
  bind:edit="onActionEdit" bind:delete="onActionDelete" bind:cancel="hideActionSheet"
/>
