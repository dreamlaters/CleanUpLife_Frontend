/**
 * 物品管理页面样式 - 统一设计语言 v3.0
 * CleanUpLife - 清新简约风格
 * 通用样式（navbar, loading, empty, footer, action-sheet, fab, top-tabs, safe-bottom）已提取到组件和 app.wxss
 */

.container {
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  overflow-x: hidden;
}

/* ==================== 统计行 ==================== */
.stats-row {
  display: flex;
  gap: 12rpx;
  padding: 0 24rpx;
  margin-bottom: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.stat-mini {
  flex: 1;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx 14rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
  border: 1rpx solid #f3f4f6;
  min-width: 0;
}

.stat-mini::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
}

.stat-primary::before {
  background: linear-gradient(90deg, #6366f1 0%, #8b5cf6 100%);
}

.stat-warning::before {
  background: linear-gradient(90deg, #f59e0b 0%, #fbbf24 100%);
}

.stat-danger::before {
  background: linear-gradient(90deg, #ef4444 0%, #f87171 100%);
}

.stat-mini-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.stat-mini-label {
  font-size: 20rpx;
  color: #9ca3af;
  margin-top: 2rpx;
}

/* ==================== 筛选标签 ==================== */
.filter-scroll {
  white-space: nowrap;
  padding: 0 24rpx;
  margin-bottom: 16rpx;
}

.filter-tabs {
  display: inline-flex;
  gap: 10rpx;
}

.filter-tab {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #ffffff;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  border: 1rpx solid #f3f4f6;
}

.filter-tab:active {
  transform: scale(0.96);
}

.filter-tab-active {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.3);
}

/* ==================== 物品列表 ==================== */
.item-list {
  padding: 16rpx 20rpx;
  background: #ffffff;
}

.item-card {
  display: flex;
  align-items: center;
  padding: 20rpx 18rpx;
  margin-bottom: 12rpx;
  background: linear-gradient(135deg, #fafbfc 0%, #f5f7fa 100%);
  border-radius: 18rpx;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  border: 1rpx solid #eef0f2;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
}

.item-card:last-child {
  margin-bottom: 0;
}

.item-card:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, #f0f1f3 0%, #ebedf0 100%);
  border-color: #e5e7eb;
}

.item-emoji {
  font-size: 32rpx;
  width: 60rpx;
  height: 60rpx;
  background: #ffffff;
  border-radius: 16rpx;
  border: 1rpx solid #eef0f2;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.04);
}

.item-content {
  flex: 1;
  margin-left: 14rpx;
  min-width: 0;
}

.item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #111827;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.item-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 6rpx;
  flex-wrap: wrap;
}

.item-location {
  font-size: 20rpx;
  color: #9ca3af;
  background: #ffffff;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.item-date-badge {
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  color: #fff;
}

.date-normal {
  background: linear-gradient(135deg, #22c55e 0%, #4ade80 100%);
}

.date-soon {
  background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);
}

.date-expired {
  background: linear-gradient(135deg, #ef4444 0%, #f87171 100%);
}

.item-arrow {
  font-size: 22rpx;
  color: #d1d5db;
  margin-left: 6rpx;
}

/* ==================== 待购清单样式 ==================== */
.tobuy-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  flex-shrink: 0;
}

.tobuy-checkbox-checked {
  background: linear-gradient(135deg, #22c55e 0%, #4ade80 100%);
  border-color: transparent;
  box-shadow: 0 2rpx 8rpx rgba(34, 197, 94, 0.3);
}

.tobuy-checkbox-checked text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

.tobuy-item {
  padding: 16rpx 14rpx;
}

.item-card-completed {
  opacity: 0.65;
}

.item-card-completed .item-name {
  color: #9ca3af;
  text-decoration: line-through;
}

.item-completed {
  opacity: 0.7;
}

.item-completed .item-name {
  text-decoration: line-through;
}

/* ==================== 优先级标签 ==================== */
.priority-badge {
  font-size: 18rpx;
  font-weight: 600;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.priority-high {
  background: rgba(239, 68, 68, 0.1);
  color: #ef4444;
}

.priority-medium {
  background: rgba(245, 158, 11, 0.1);
  color: #d97706;
}

.priority-low {
  background: rgba(34, 197, 94, 0.1);
  color: #22c55e;
}

/* ==================== 已完成区域 ==================== */
.completed-section {
  margin-top: 16rpx;
}

.completed-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.completed-title-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.completed-icon {
  font-size: 22rpx;
}

.completed-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #6b7280;
}

.completed-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.clear-btn {
  font-size: 22rpx;
  color: #ef4444;
  padding: 6rpx 14rpx;
  background: rgba(239, 68, 68, 0.08);
  border-radius: 10rpx;
}

.expand-icon {
  font-size: 24rpx;
  color: #9ca3af;
  transition: transform 0.25s ease;
  transform: rotate(90deg);
}

.expand-icon-up {
  transform: rotate(-90deg);
}

.completed-list {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.completed-list-show {
  max-height: 800rpx;
}

/* ==================== 待购表单弹窗 ==================== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  animation: slideUp 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  padding-bottom: env(safe-area-inset-bottom);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.modal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #9ca3af;
  border-radius: 50%;
  background: #f9fafb;
}

.modal-body {
  padding: 24rpx;
}

.modal-footer {
  padding: 16rpx 24rpx 24rpx;
  display: flex;
  gap: 12rpx;
}

.form-group {
  margin-bottom: 20rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-group .form-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #6b7280;
  margin-bottom: 10rpx;
  display: block;
}

.form-group .form-input {
  width: 100%;
  min-height: auto;
  padding: 18rpx 20rpx;
  background: #f9fafb;
  border: 2rpx solid transparent;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: #111827;
  box-sizing: border-box;
  transition: all 0.15s;
}

.form-group .form-input:focus {
  background: #ffffff;
  border-color: #6366f1;
  box-shadow: none;
}

.btn {
  flex: 1;
  padding: 18rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  transition: all 0.15s;
}

.btn:active {
  transform: scale(0.98);
}

.btn-cancel {
  background: #f3f4f6;
  color: #6b7280;
}

.btn-primary {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(99, 102, 241, 0.35);
}
