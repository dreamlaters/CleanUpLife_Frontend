<!-- 记录页面 - 猫猫体重 + 姨妈记录 + 体检记录 -->
<view class="container">
  <!-- 自定义导航栏 -->
  <view class="custom-navbar" style="padding-top: {{statusBarHeight}}px">
    <view class="navbar-content">
      <text class="navbar-title">我的记录</text>
    </view>
  </view>
  <view class="navbar-placeholder" style="height: {{navbarHeight}}px"></view>

  <!-- 顶部Tab切换 -->
  <view class="top-tabs">
    <view class="top-tab {{currentTab === 'weight' ? 'top-tab-active' : ''}}" bindtap="switchTab" data-tab="weight">
      <text class="top-tab-icon">🐱</text>
      <text class="top-tab-text">猫猫体重</text>
    </view>
    <view class="top-tab {{currentTab === 'period' ? 'top-tab-active' : ''}}" bindtap="switchTab" data-tab="period">
      <text class="top-tab-icon">🌸</text>
      <text class="top-tab-text">姨妈记录</text>
    </view>
    <view class="top-tab {{currentTab === 'checkup' ? 'top-tab-active' : ''}}" bindtap="switchTab" data-tab="checkup">
      <text class="top-tab-icon">🏥</text>
      <text class="top-tab-text">体检记录</text>
    </view>
  </view>

  <!-- ==================== 体重内容 ==================== -->
  <view class="tab-content" wx:if="{{currentTab === 'weight'}}">
    <!-- 宠物卡片 -->
    <view class="pet-cards">
      <view 
        class="pet-card" 
        wx:for="{{personList}}" 
        wx:key="*this" 
        wx:for-item="person"
        style="--accent-color: {{personConfig[person].color}}"
      >
        <view class="pet-card-accent"></view>
        <view class="pet-avatar">
          <text class="pet-emoji">{{personConfig[person].emoji}}</text>
        </view>
        <view class="pet-info">
          <text class="pet-name">{{person}}</text>
          <view class="pet-weight-wrap">
            <text class="pet-weight">{{latestWeights[person] || '--'}}</text>
            <text class="pet-unit">斤</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 图表区域 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-title-wrap">
          <view class="section-icon">📈</view>
          <text class="section-title">体重趋势</text>
        </view>
      </view>
      
      <!-- 时间范围筛选 -->
      <view class="filter-tabs">
        <view class="filter-tab {{timeRange === 'week' ? 'filter-tab-active' : ''}}" 
              bindtap="onTimeRangeChange" data-range="week">近7天</view>
        <view class="filter-tab {{timeRange === 'month' ? 'filter-tab-active' : ''}}" 
              bindtap="onTimeRangeChange" data-range="month">近30天</view>
        <view class="filter-tab {{timeRange === '3month' ? 'filter-tab-active' : ''}}" 
              bindtap="onTimeRangeChange" data-range="3month">近3月</view>
        <view class="filter-tab {{timeRange === 'all' ? 'filter-tab-active' : ''}}" 
              bindtap="onTimeRangeChange" data-range="all">全部</view>
      </view>

      <!-- Canvas 折线图 -->
      <view class="chart-wrapper">
        <view class="chart-container" wx:if="{{!showWeightForm}}">
          <canvas type="2d" id="weight-canvas" class="weight-canvas"></canvas>
        </view>
        <view class="chart-container chart-placeholder" wx:else>
          <text class="placeholder-icon">📊</text>
          <text class="placeholder-text">编辑中...</text>
        </view>
      </view>

      <!-- 图例 -->
      <view class="chart-legend">
        <view class="legend-item" wx:for="{{personList}}" wx:key="*this" wx:for-item="person">
          <view class="legend-dot" style="background: {{personConfig[person].color}}"></view>
          <text class="legend-text">{{person}}</text>
        </view>
      </view>
    </view>

    <!-- 记录列表 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-title-wrap">
          <view class="section-icon">📋</view>
          <text class="section-title">记录明细</text>
        </view>
        <view class="section-badge" wx:if="{{weightRecords.length}}">{{weightRecords.length}}条</view>
      </view>

      <view class="loading-container" wx:if="{{loadingWeight}}">
        <view class="loading-spinner"></view>
        <text class="loading-text">加载中...</text>
      </view>

      <view class="records-container" wx:elif="{{weightRecords.length}}">
        <view class="person-group" wx:for="{{personList}}" wx:key="*this" wx:for-item="person" wx:if="{{groupedRecords[person].length}}">
          <view class="person-header">
            <view class="person-info">
              <text class="person-emoji">{{personConfig[person].emoji}}</text>
              <text class="person-name" style="color: {{personConfig[person].color}}">{{person}}</text>
            </view>
            <view class="person-badge">{{groupedRecords[person].length}}条</view>
          </view>
          
          <view class="record-grid">
            <view 
              class="record-card"
              wx:for="{{groupedRecords[person]}}" 
              wx:key="id"
              wx:for-item="record"
              data-id="{{record.id}}"
              data-person="{{person}}"
              bindtap="onWeightRecordTap"
              bindlongpress="onWeightRecordLongPress"
            >
              <text class="record-date">{{record.recordDateFormatted}}</text>
              <view class="record-value" style="color: {{personConfig[person].color}}">
                <text class="record-weight">{{record.weight}}</text>
                <text class="record-unit">斤</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="empty-state" wx:if="{{!loadingWeight && !weightRecords.length}}">
        <text class="empty-icon">⚖️</text>
        <text class="empty-title">还没有体重记录</text>
        <text class="empty-text">点击下方按钮，开始记录宝贝的体重</text>
        <view class="empty-btn" bindtap="showAddWeightForm">+ 添加记录</view>
      </view>
    </view>

    <!-- 悬浮添加按钮 -->
    <view class="fab-btn" bindtap="showAddWeightForm" wx:if="{{!showWeightForm}}">
      <text class="fab-icon">+</text>
    </view>

    <!-- 底部消息推送入口 -->
    <view class="footer-link-wrap">
      <navigator url="/pages/openid/openid" class="footer-link">
        <text class="footer-link-icon">🔔</text>
        <text class="footer-link-text">消息推送设置</text>
        <text class="footer-link-arrow">›</text>
      </navigator>
    </view>
  </view>

  <!-- ==================== 姨妈内容 ==================== -->
  <view class="tab-content" wx:if="{{currentTab === 'period'}}">
    <!-- 状态卡片 -->
    <view class="period-status-card" wx:if="{{periodStats}}">
      <view class="period-status-icon">🌸</view>
      <view class="period-status-info">
        <view class="period-status-main" wx:if="{{periodStats.status === 'none'}}">
          <text class="period-status-text">暂无记录</text>
          <text class="period-status-hint">点击下方按钮开始记录</text>
        </view>
        <view class="period-status-main" wx:elif="{{periodStats.status === 'in-period'}}">
          <text class="period-status-text">经期第 {{periodDays}} 天</text>
          <text class="period-status-hint">记得注意保暖哦 💕</text>
        </view>
        <view class="period-status-main" wx:else>
          <text class="period-status-text" wx:if="{{periodStats.daysUntilNextPeriod > 0}}">距下次姨妈还有 {{periodStats.daysUntilNextPeriod}} 天
          </text>
          <text class="period-status-text" wx:elif="{{periodStats.daysUntilNextPeriod === 0}}">
            预计今天开始
          </text>
          <text class="period-status-text" wx:else>
            已超出预计 {{0 - periodStats.daysUntilNextPeriod}} 天
          </text>
          <text class="period-status-hint">平均周期 {{periodStats.averageCycleDays}} 天</text>
        </view>
      </view>
    </view>

    <!-- 日历区域 -->
    <view class="calendar-card">
      <!-- 月份导航 -->
      <view class="calendar-header">
        <view class="month-nav" bindtap="prevMonth">
          <text class="nav-arrow">‹</text>
        </view>
        <view class="month-title">
          <text>{{currentYear}}年{{currentMonth}}月</text>
        </view>
        <view class="month-nav" bindtap="nextMonth">
          <text class="nav-arrow">›</text>
        </view>
        <view class="today-btn" bindtap="goToToday">
          <text>今天</text>
        </view>
      </view>

      <!-- 星期标题 -->
      <view class="weekday-row">
        <view class="weekday-cell" wx:for="{{weekDays}}" wx:key="*this">
          <text class="{{index === 0 || index === 6 ? 'weekend' : ''}}">{{item}}</text>
        </view>
      </view>

      <!-- 日期网格 -->
      <view class="calendar-grid">
        <view 
          class="day-cell {{item.isCurrentMonth ? '' : 'other-month'}} {{item.isToday ? 'today' : ''}} {{item.isPeriod ? 'period' : ''}} {{item.isPredicted ? 'predicted' : ''}} {{item.isStart ? 'period-start' : ''}} {{item.isEnd ? 'period-end' : ''}}"
          wx:for="{{calendarDays}}" 
          wx:key="date"
        >
          <text class="day-num">{{item.day}}</text>
          <view class="day-dot" wx:if="{{item.isPeriod || item.isPredicted}}"></view>
        </view>
      </view>

      <!-- 图例 -->
      <view class="period-legend">
        <view class="period-legend-item">
          <view class="period-legend-dot period"></view>
          <text>经期</text>
        </view>
        <view class="period-legend-item">
          <view class="period-legend-dot predicted"></view>
          <text>预测</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="period-action-buttons">
      <button class="period-action-btn primary" bindtap="showRecordStart" wx:if="{{!latestPeriodRecord || latestPeriodRecord.endDate}}">
        <text class="period-btn-icon">🩸</text>
        <text>记录开始</text>
      </button>
      <button class="period-action-btn secondary" bindtap="showRecordEnd" wx:if="{{latestPeriodRecord && !latestPeriodRecord.endDate}}">
        <text class="period-btn-icon">✓</text>
        <text>记录结束</text>
      </button>
      <button class="period-action-btn outline" bindtap="showRecordStart" wx:if="{{latestPeriodRecord && !latestPeriodRecord.endDate}}">
        <text class="period-btn-icon">📝</text>
        <text>新记录</text>
      </button>
    </view>

    <!-- 历史记录列表 -->
    <view class="section-card" wx:if="{{periodRecords.length > 0}}">
      <view class="section-header">
        <view class="section-title-wrap">
          <view class="section-icon">📋</view>
          <text class="section-title">历史记录</text>
        </view>
      </view>
      <view class="period-record-list">
        <view 
          class="period-record-item" 
          wx:for="{{periodRecords}}" 
          wx:key="id"
          bindtap="onPeriodRecordTap"
          data-record="{{item}}"
        >
          <view class="period-record-dates">
            <text class="period-record-start">{{item.startDate.split('T')[0]}}</text>
            <text class="period-record-arrow">→</text>
            <text class="period-record-end">{{item.endDate ? item.endDate.split('T')[0] : '进行中'}}</text>
          </view>
          <view class="period-record-info">
            <text class="period-record-days" wx:if="{{item.periodDays}}">{{item.periodDays}}天</text>
            <text class="period-record-cycle" wx:if="{{item.cycleDays}}">周期{{item.cycleDays}}天</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部消息推送入口 -->
    <view class="footer-link-wrap">
      <navigator url="/pages/openid/openid" class="footer-link">
        <text class="footer-link-icon">🔔</text>
        <text class="footer-link-text">消息推送设置</text>
        <text class="footer-link-arrow">›</text>
      </navigator>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loadingPeriod && periodRecords.length === 0}}">
      <text class="empty-icon">📅</text>
      <text class="empty-title">暂无记录</text>
      <text class="empty-text">点击"记录开始"添加第一条记录</text>
    </view>

    <!-- 加载状态 -->
    <view class="loading-container" wx:if="{{loadingPeriod}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>
  <!-- ==================== 体检内容 ==================== -->
  <view class="tab-content" wx:if="{{currentTab === 'checkup'}}">
    <!-- 人员切换 -->
    <view class="checkup-owner-tabs">
      <view 
        class="checkup-owner-tab {{checkupOwner === item ? 'checkup-owner-tab-active' : ''}}"
        wx:for="{{checkupOwners}}"
        wx:key="*this"
        wx:for-item="item"
        bindtap="onCheckupOwnerChange"
        data-owner="{{item}}"
      >
        <text class="checkup-owner-emoji">{{checkupOwnerConfig[item].emoji}}</text>
        <text class="checkup-owner-name">{{checkupOwnerConfig[item].name}}</text>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-container" wx:if="{{loadingCheckup}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 最近体检概览卡片 -->
    <view class="checkup-summary-card" wx:if="{{checkupRecords.length > 0 && !loadingCheckup}}">
      <view class="checkup-summary-icon">📋</view>
      <view class="checkup-summary-info">
        <text class="checkup-summary-title">最近一次体检</text>
        <text class="checkup-summary-date">{{checkupRecords[0].checkupDateFormatted}}</text>
        <text class="checkup-summary-hospital" wx:if="{{checkupRecords[0].hospital}}">{{checkupRecords[0].hospital}}</text>
      </view>
      <view class="checkup-summary-stats">
        <view class="checkup-stat-item" wx:if="{{checkupRecords[0].abnormalCount > 0}}">
          <text class="checkup-stat-num abnormal">{{checkupRecords[0].abnormalCount}}</text>
          <text class="checkup-stat-label">异常</text>
        </view>
        <view class="checkup-stat-item">
          <text class="checkup-stat-num normal">{{checkupRecords[0].normalCount}}</text>
          <text class="checkup-stat-label">正常</text>
        </view>
      </view>
    </view>

    <!-- 体检记录列表 -->
    <view class="section-card" wx:if="{{checkupRecords.length > 0 && !loadingCheckup}}">
      <view class="section-header">
        <view class="section-title-wrap">
          <view class="section-icon">📅</view>
          <text class="section-title">历史记录</text>
        </view>
        <view class="section-badge">{{checkupRecords.length}}次</view>
      </view>

      <view class="checkup-record-list">
        <view 
          class="checkup-record-item"
          wx:for="{{checkupRecords}}"
          wx:key="id"
          bindtap="goToCheckupDetail"
          bindlongpress="onCheckupLongPress"
          data-id="{{item.id}}"
        >
          <view class="checkup-record-left">
            <text class="checkup-record-date">{{item.checkupDateFormatted}}</text>
            <text class="checkup-record-hospital" wx:if="{{item.hospital}}">{{item.hospital}}</text>
          </view>
          <view class="checkup-record-right">
            <view class="checkup-badge abnormal" wx:if="{{item.abnormalCount > 0}}">
              <text>⚠️ {{item.abnormalCount}}项异常</text>
            </view>
            <view class="checkup-badge normal">
              <text>✅ {{item.normalCount}}项正常</text>
            </view>
            <text class="checkup-record-arrow">›</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loadingCheckup && checkupRecords.length === 0}}">
      <text class="empty-icon">🏥</text>
      <text class="empty-title">暂无体检记录</text>
      <text class="empty-text">点击下方按钮，开始记录体检结果</text>
    </view>

    <!-- 悬浮添加按钮 -->
    <view class="fab-btn" bindtap="goToAddCheckup">
      <text class="fab-icon">+</text>
    </view>

    <!-- 底部消息推送入口 -->
    <view class="footer-link-wrap">
      <navigator url="/pages/openid/openid" class="footer-link">
        <text class="footer-link-icon">🔔</text>
        <text class="footer-link-text">消息推送设置</text>
        <text class="footer-link-arrow">›</text>
      </navigator>
    </view>
  </view>
  <view class="safe-bottom"></view>
</view>

<!-- ==================== 体重表单弹窗 ==================== -->
<view class="modal-overlay {{showWeightForm ? 'show' : ''}}" catchtap="hideWeightForm" wx:if="{{showWeightForm}}">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">{{editingWeightId ? '✏️ 编辑记录' : '➕ 添加记录'}}</text>
      <view class="modal-close" bindtap="hideWeightForm">×</view>
    </view>

    <view class="modal-body" catchtap="stopPropagation">
      <view class="form-group">
        <text class="form-label">🐾 选择宝贝</text>
        <view class="person-selector">
          <view 
            class="person-option {{formPersonIndex === index ? 'person-option-active' : ''}}"
            wx:for="{{personList}}"
            wx:key="*this"
            wx:for-item="person"
            data-index="{{index}}"
            bindtap="onPersonSelect"
            style="--person-color: {{personConfig[person].color}}"
          >
            <text class="option-emoji">{{personConfig[person].emoji}}</text>
            <text class="option-name">{{person}}</text>
          </view>
        </view>
      </view>

      <view class="form-group">
        <text class="form-label">⚖️ 体重（斤）</text>
        <view class="input-wrapper">
          <input 
            class="weight-input" 
            type="digit" 
            placeholder="请输入体重"
            value="{{formWeight}}"
            bindinput="onWeightInput"
          />
          <text class="input-suffix">斤</text>
        </view>
      </view>

      <view class="form-group">
        <text class="form-label">📅 记录日期</text>
        <picker mode="date" value="{{formDate}}" bindchange="onWeightDateChange">
          <view class="date-picker">
            <text class="date-value">{{formDate}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>

    <view class="modal-footer">
      <button class="btn btn-secondary" bindtap="hideWeightForm">取消</button>
      <button class="btn btn-primary" bindtap="submitWeightForm">确定</button>
    </view>
  </view>
</view>

<!-- 体重操作菜单 -->
<view class="action-overlay {{showWeightActionSheet ? 'show' : ''}}" bindtap="hideWeightActionSheet" wx:if="{{showWeightActionSheet}}">
  <view class="action-sheet" catchtap="">
    <view class="action-header">
      <text class="action-title">{{weightActionSheetPerson}} 的记录</text>
    </view>
    <view class="action-item" bindtap="onEditWeightAction">
      <text class="action-icon">✏️</text>
      <text class="action-text">编辑记录</text>
    </view>
    <view class="action-item action-danger" bindtap="onDeleteWeightAction">
      <text class="action-icon">🗑️</text>
      <text class="action-text">删除记录</text>
    </view>
    <view class="action-cancel" bindtap="hideWeightActionSheet">取消</view>
  </view>
</view>

<!-- ==================== 姨妈弹窗 ==================== -->
<!-- 记录开始弹窗 -->
<view class="modal-overlay {{showStartModal ? 'show' : ''}}" catchtap="hideStartModal" wx:if="{{showStartModal}}">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">记录开始日期</text>
      <view class="modal-close" bindtap="hideStartModal">×</view>
    </view>
    <view class="modal-body">
      <view class="form-group">
        <text class="form-label">开始日期</text>
        <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
          <view class="date-picker">
            <text class="date-value">{{startDate}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
      <view class="form-group">
        <text class="form-label">备注（可选）</text>
        <input class="form-input" placeholder="添加备注..." value="{{notes}}" bindinput="onNotesInput" />
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn btn-secondary" bindtap="hideStartModal">取消</button>
      <button class="btn btn-primary btn-pink" bindtap="submitStart">确定</button>
    </view>
  </view>
</view>

<!-- 记录结束弹窗 -->
<view class="modal-overlay {{showEndModal ? 'show' : ''}}" catchtap="hideEndModal" wx:if="{{showEndModal}}">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">记录结束日期</text>
      <view class="modal-close" bindtap="hideEndModal">×</view>
    </view>
    <view class="modal-body">
      <view class="form-group">
        <text class="form-label">结束日期</text>
        <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
          <view class="date-picker">
            <text class="date-value">{{endDate}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn btn-secondary" bindtap="hideEndModal">取消</button>
      <button class="btn btn-primary btn-pink" bindtap="submitEnd">确定</button>
    </view>
  </view>
</view>

<!-- 编辑弹窗 -->
<view class="modal-overlay {{showPeriodEditModal ? 'show' : ''}}" catchtap="hidePeriodEditModal" wx:if="{{showPeriodEditModal}}">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">编辑记录</text>
      <view class="modal-close" bindtap="hidePeriodEditModal">×</view>
    </view>
    <view class="modal-body">
      <view class="form-group">
        <text class="form-label">开始日期</text>
        <picker mode="date" value="{{editStartDate}}" bindchange="onEditStartDateChange">
          <view class="date-picker">
            <text class="date-value">{{editStartDate}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
      <view class="form-group">
        <text class="form-label">结束日期</text>
        <picker mode="date" value="{{editEndDate}}" bindchange="onEditEndDateChange">
          <view class="date-picker">
            <text class="date-value">{{editEndDate || '未设置'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
      <view class="form-group">
        <text class="form-label">备注</text>
        <input class="form-input" placeholder="添加备注..." value="{{editNotes}}" bindinput="onEditNotesInput" />
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn btn-danger" bindtap="deletePeriodRecord">删除</button>
      <button class="btn btn-primary btn-pink" bindtap="submitPeriodEdit">保存</button>
    </view>
  </view>
</view>

<!-- ==================== 体检操作菜单 ==================== -->
<view class="action-overlay {{showCheckupActionSheet ? 'show' : ''}}" bindtap="hideCheckupActionSheet" wx:if="{{showCheckupActionSheet}}">
  <view class="action-sheet" catchtap="">
    <view class="action-header">
      <text class="action-title">体检记录操作</text>
    </view>
    <view class="action-item" bindtap="onEditCheckupAction">
      <text class="action-icon">✏️</text>
      <text class="action-text">编辑记录</text>
    </view>
    <view class="action-item action-danger" bindtap="onDeleteCheckupAction">
      <text class="action-icon">🗑️</text>
      <text class="action-text">删除记录</text>
    </view>
    <view class="action-cancel" bindtap="hideCheckupActionSheet">取消</view>
  </view>
</view>
