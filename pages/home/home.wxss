/**
 * 首页样式 - 统一设计语言 v3.0
 * CleanUpLife - 清新简约风格
 * 通用样式（navbar, loading, footer, safe-bottom）已提取到组件和 app.wxss
 */

/* ==================== 通用区块卡片 ==================== */
.section-card {
  margin: 20rpx 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  background: rgba(99, 102, 241, 0.1);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

/* ==================== 过期提醒 ==================== */
.alert-card {
  border-left: 5rpx solid #f59e0b;
  background: linear-gradient(135deg, #fffbeb 0%, #ffffff 30%);
}

.alert-badge {
  font-size: 22rpx;
  color: #fff;
  background: linear-gradient(135deg, #ef4444 0%, #f87171 100%);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(239, 68, 68, 0.25);
}

.alert-group {
  padding: 20rpx 28rpx 24rpx;
}

.alert-group:not(:last-child) {
  border-bottom: 1rpx solid #f3f4f6;
}

.alert-group-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.alert-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
}

.alert-danger .alert-dot {
  background: #ef4444;
  box-shadow: 0 0 6rpx rgba(239, 68, 68, 0.5);
}

.alert-warning .alert-dot {
  background: #f59e0b;
  box-shadow: 0 0 6rpx rgba(245, 158, 11, 0.5);
}

.alert-group-title {
  font-size: 24rpx;
  font-weight: 500;
  color: #6b7280;
}

.alert-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.alert-item {
  display: flex;
  align-items: center;
  padding: 16rpx 18rpx;
  background: #ffffff;
  border-radius: 16rpx;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  border: 1rpx solid #f3f4f6;
}

.alert-item:active {
  transform: scale(0.98);
  background: #f9fafb;
  border-color: #e5e7eb;
}

.alert-item-emoji {
  font-size: 28rpx;
  width: 52rpx;
  height: 52rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.alert-item-info {
  flex: 1;
  margin-left: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.alert-item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #111827;
}

.alert-item-date {
  font-size: 22rpx;
  font-weight: 500;
}

.alert-item-date.danger {
  color: #ef4444;
}

.alert-item-date.warning {
  color: #d97706;
}

.alert-item-arrow {
  font-size: 24rpx;
  color: #d1d5db;
}

/* ==================== 空提醒状态 ==================== */
.empty-alert-card {
  border-left: 5rpx solid #22c55e;
  background: linear-gradient(135deg, #f0fdf4 0%, #ffffff 30%);
}

.empty-alert-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx;
}

.empty-alert-icon {
  font-size: 52rpx;
  margin-bottom: 16rpx;
}

.empty-alert-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #22c55e;
  margin-bottom: 6rpx;
}

.empty-alert-text {
  font-size: 24rpx;
  color: #9ca3af;
}

/* ==================== 姨妈记录卡片 ==================== */
.period-card {
  border-left: 5rpx solid #ec4899;
  background: linear-gradient(135deg, #fdf2f8 0%, #ffffff 30%);
}

.period-card-content {
  display: flex;
  align-items: center;
  padding: 28rpx;
  gap: 20rpx;
}

.period-icon {
  font-size: 44rpx;
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #fce7f3 0%, #fbcfe8 100%);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.period-info {
  flex: 1;
}

.period-status {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.period-main-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #be185d;
}

.period-sub-text {
  font-size: 24rpx;
  color: #9ca3af;
}

.period-arrow {
  font-size: 32rpx;
  color: #f9a8d4;
}

/* ==================== 快捷入口 ==================== */
.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  padding: 20rpx 24rpx 28rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 8rpx;
  border-radius: 16rpx;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.quick-item:active {
  transform: scale(0.92);
  background: #f9fafb;
}

.quick-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.quick-icon-primary {
  background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%);
}

.quick-icon-success {
  background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);
}

.quick-icon-info {
  background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%);
}

.quick-icon-warning {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
}

.quick-label {
  font-size: 22rpx;
  color: #4b5563;
  font-weight: 500;
}

/* ==================== 统计概览 ==================== */
.stats-section {
  padding: 0 28rpx 28rpx;
}

.stats-divider {
  height: 1rpx;
  background: #f3f4f6;
  margin-bottom: 24rpx;
}

.stats-grid {
  display: flex;
  gap: 16rpx;
}

.stat-item {
  flex: 1;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: 16rpx;
  padding: 24rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-item:active {
  transform: scale(0.96);
  background: #e2e8f0;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #6366f1;
  padding: 0 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 6rpx;
  font-weight: 500;
}
