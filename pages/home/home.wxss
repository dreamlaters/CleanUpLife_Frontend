/**
 * 首页样式 - 生活状态仪表盘
 * CleanUpLife - 清新简约风格
 */

/* ==================== 通用区块卡片 ==================== */
.section-card {
  margin: 20rpx 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  background: rgba(99, 102, 241, 0.1);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.section-arrow {
  font-size: 28rpx;
  color: #d1d5db;
}

/* ==================== 过期提醒 ==================== */
.alert-card {
  border-left: 5rpx solid #f59e0b;
  background: linear-gradient(135deg, #fffbeb 0%, #ffffff 30%);
}

.alert-badge {
  font-size: 22rpx;
  color: #fff;
  background: linear-gradient(135deg, #ef4444 0%, #f87171 100%);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(239, 68, 68, 0.25);
}

.alert-group {
  padding: 12rpx 28rpx 16rpx;
}

.alert-group:not(:last-child) {
  border-bottom: 1rpx solid #f3f4f6;
}

.alert-group-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.alert-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
}

.alert-danger .alert-dot {
  background: #ef4444;
  box-shadow: 0 0 6rpx rgba(239, 68, 68, 0.5);
}

.alert-warning .alert-dot {
  background: #f59e0b;
  box-shadow: 0 0 6rpx rgba(245, 158, 11, 0.5);
}

.alert-group-title {
  font-size: 24rpx;
  font-weight: 500;
  color: #6b7280;
}

.alert-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.alert-item {
  display: flex;
  align-items: center;
  padding: 12rpx 14rpx;
  background: #ffffff;
  border-radius: 12rpx;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  border: 1rpx solid #f3f4f6;
}

.alert-item:active {
  transform: scale(0.98);
  background: #f9fafb;
  border-color: #e5e7eb;
}

.alert-item-emoji {
  font-size: 24rpx;
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.alert-item-info {
  flex: 1;
  margin-left: 12rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.alert-item-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #111827;
}

.alert-item-date {
  font-size: 20rpx;
  font-weight: 500;
}

.alert-item-date.danger {
  color: #ef4444;
}

.alert-item-date.warning {
  color: #d97706;
}

.alert-item-arrow {
  font-size: 24rpx;
  color: #d1d5db;
}

/* ==================== 空提醒状态 ==================== */
.empty-alert-card {
  border-left: 5rpx solid #22c55e;
  background: linear-gradient(135deg, #f0fdf4 0%, #ffffff 30%);
}

.empty-alert-icon-wrap {
  font-size: 44rpx;
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-alert-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #22c55e;
}

/* ==================== 姨妈记录卡片 ==================== */
.period-card {
  border-left: 5rpx solid #ec4899;
  background: linear-gradient(135deg, #fdf2f8 0%, #ffffff 30%);
}

.period-card-content {
  display: flex;
  align-items: center;
  padding: 28rpx;
  gap: 20rpx;
}

.period-icon {
  font-size: 44rpx;
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #fce7f3 0%, #fbcfe8 100%);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.period-info {
  flex: 1;
}

.period-status {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.period-main-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #be185d;
}

.period-sub-text {
  font-size: 24rpx;
  color: #9ca3af;
}

.period-arrow {
  font-size: 32rpx;
  color: #f9a8d4;
}

/* ==================== 猫猫体重卡片 ==================== */
.cat-card {
  border-left: 5rpx solid #f59e0b;
  background: linear-gradient(135deg, #fffbeb 0%, #ffffff 30%);
}

.cat-grid {
  display: flex;
  gap: 1rpx;
  background: #f3f4f6;
}

.cat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #ffffff;
}

.cat-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.cat-weight-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.cat-weight {
  font-size: 44rpx;
  font-weight: 700;
  color: #d97706;
}

.cat-unit {
  font-size: 22rpx;
  color: #9ca3af;
}

.cat-date {
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 6rpx;
}

/* ==================== 年度目标卡片 ==================== */
.goals-card {
  border-left: 5rpx solid #6366f1;
  background: linear-gradient(135deg, #eef2ff 0%, #ffffff 30%);
}

.goals-list {
  padding: 20rpx 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.goals-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.goals-owner {
  font-size: 28rpx;
  width: 40rpx;
  text-align: center;
  flex-shrink: 0;
}

.goals-progress-bar {
  flex: 1;
  height: 16rpx;
  background: #f3f4f6;
  border-radius: 8rpx;
  overflow: hidden;
}

.goals-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.goals-progress-fill-donkey {
  background: linear-gradient(90deg, #ec4899 0%, #f472b6 100%);
}

.goals-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #6b7280;
  width: 60rpx;
  text-align: right;
  flex-shrink: 0;
}

/* ==================== 统计行 ==================== */
.stats-row {
  display: flex;
  gap: 16rpx;
  margin: 20rpx 24rpx;
}

.stat-item {
  flex: 1;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.stat-item:active {
  transform: scale(0.96);
  background: #f9fafb;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #6366f1;
}

.stat-label {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 6rpx;
  font-weight: 500;
}
