<!-- 首页 - 生活状态仪表盘 -->
<view class="container">
  <!-- 自定义导航栏 -->
  <custom-navbar greeting="{{greeting}}" dateText="{{dateText}}" statusBarHeight="{{statusBarHeight}}" navbarHeight="{{navbarHeight}}" />

  <!-- 加载状态 -->
  <loading-state loading="{{loading}}" />

  <!-- 过期提醒区域 -->
  <view class="section-card alert-card" wx:if="{{expiredItems.length || expiringSoonItems.length}}">
    <view class="section-header">
      <view class="section-title-wrap">
        <view class="section-icon">⚠️</view>
        <text class="section-title">过期提醒</text>
      </view>
      <view class="alert-badge" wx:if="{{expiredItems.length + expiringSoonItems.length}}">
        {{expiredItems.length + expiringSoonItems.length}}件
      </view>
    </view>

    <!-- 已过期物品 -->
    <view class="alert-group" wx:if="{{expiredItems.length}}">
      <view class="alert-group-header alert-danger">
        <text class="alert-dot"></text>
        <text class="alert-group-title">已过期 ({{expiredItems.length}})</text>
      </view>
      <view class="alert-list">
        <view
          class="alert-item"
          wx:for="{{expiredItems}}"
          wx:key="id"
          bindtap="goToUpdateItem"
          data-id="{{item.id}}"
          data-category="{{item.category}}"
        >
          <text class="alert-item-emoji">{{item.emoji || '📦'}}</text>
          <view class="alert-item-info">
            <text class="alert-item-name">{{item.name}}</text>
            <text class="alert-item-date danger">过期{{item.daysText}}</text>
          </view>
          <text class="alert-item-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 即将过期物品 -->
    <view class="alert-group" wx:if="{{expiringSoonItems.length}}">
      <view class="alert-group-header alert-warning">
        <text class="alert-dot"></text>
        <text class="alert-group-title">即将过期 ({{expiringSoonItems.length}})</text>
      </view>
      <view class="alert-list">
        <view
          class="alert-item"
          wx:for="{{expiringSoonItems}}"
          wx:key="id"
          bindtap="goToUpdateItem"
          data-id="{{item.id}}"
          data-category="{{item.category}}"
        >
          <text class="alert-item-emoji">{{item.emoji || '📦'}}</text>
          <view class="alert-item-info">
            <text class="alert-item-name">{{item.name}}</text>
            <text class="alert-item-date warning">{{item.daysText}}后过期</text>
          </view>
          <text class="alert-item-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 无提醒时的空状态 -->
  <view class="section-card empty-alert-card" wx:if="{{!loading && !expiredItems.length && !expiringSoonItems.length}}">
    <view class="empty-alert-content">
      <text class="empty-alert-icon">✨</text>
      <text class="empty-alert-title">太棒了！</text>
      <text class="empty-alert-text">没有即将过期的物品</text>
    </view>
  </view>

  <!-- 姨妈记录状态卡片 -->
  <view class="section-card period-card" bindtap="goToPeriod" wx:if="{{periodStats}}">
    <view class="period-card-content">
      <view class="period-icon">🌸</view>
      <view class="period-info">
        <view class="period-status" wx:if="{{periodStats.status === 'none'}}">
          <text class="period-main-text">暂无记录</text>
          <text class="period-sub-text">点击开始记录</text>
        </view>
        <view class="period-status" wx:elif="{{periodStats.status === 'in-period'}}">
          <text class="period-main-text">经期中</text>
          <text class="period-sub-text">注意保暖 💕</text>
        </view>
        <view class="period-status" wx:else>
          <text class="period-main-text" wx:if="{{periodStats.daysUntilNextPeriod > 0}}">距下次姨妈还有 {{periodStats.daysUntilNextPeriod}} 天</text>
          <text class="period-main-text" wx:elif="{{periodStats.daysUntilNextPeriod === 0}}">预计今天开始</text>
          <text class="period-main-text" wx:else>已超出预计 {{-periodStats.daysUntilNextPeriod}} 天</text>
          <text class="period-sub-text">平均周期 {{periodStats.averageCycleDays}} 天</text>
        </view>
      </view>
      <view class="period-arrow">›</view>
    </view>
  </view>

  <!-- 猫猫体重卡片 -->
  <view class="section-card cat-card" bindtap="goToWeight" wx:if="{{catWeights.length}}">
    <view class="section-header">
      <view class="section-title-wrap">
        <view class="section-icon">🐱</view>
        <text class="section-title">猫猫体重</text>
      </view>
      <text class="section-arrow">›</text>
    </view>
    <view class="cat-grid">
      <view class="cat-item" wx:for="{{catWeights}}" wx:key="personName">
        <text class="cat-name">{{item.personName}}</text>
        <view class="cat-weight-row">
          <text class="cat-weight">{{item.weight}}</text>
          <text class="cat-unit">斤</text>
        </view>
        <text class="cat-date">{{item.dateText}}</text>
      </view>
    </view>
  </view>

  <!-- 年度目标卡片 -->
  <view class="section-card goals-card" bindtap="goToGoals" wx:if="{{goalsPig.length || goalsDonkey.length}}">
    <view class="section-header">
      <view class="section-title-wrap">
        <view class="section-icon">🎯</view>
        <text class="section-title">年度目标</text>
      </view>
      <text class="section-arrow">›</text>
    </view>
    <view class="goals-list">
      <view class="goals-row" wx:if="{{goalsPig.length}}">
        <text class="goals-owner">🐷</text>
        <view class="goals-progress-bar">
          <view class="goals-progress-fill" style="width: {{pigProgress}}%"></view>
        </view>
        <text class="goals-text">{{pigCompleted}}/{{goalsPig.length}}</text>
      </view>
      <view class="goals-row" wx:if="{{goalsDonkey.length}}">
        <text class="goals-owner">🫏</text>
        <view class="goals-progress-bar">
          <view class="goals-progress-fill goals-progress-fill-donkey" style="width: {{donkeyProgress}}%"></view>
        </view>
        <text class="goals-text">{{donkeyCompleted}}/{{goalsDonkey.length}}</text>
      </view>
    </view>
  </view>

  <!-- 统计行 -->
  <view class="stats-row" wx:if="{{!loading}}">
    <view class="stat-item" bindtap="goToItems">
      <text class="stat-value">{{totalItems}}</text>
      <text class="stat-label">物品</text>
    </view>
    <view class="stat-item" bindtap="goToToBuyList">
      <text class="stat-value">{{toBuyCount}}</text>
      <text class="stat-label">待购</text>
    </view>
    <view class="stat-item" bindtap="goToTravel">
      <text class="stat-value">{{travelCount}}</text>
      <text class="stat-label">想去</text>
    </view>
  </view>

  <!-- 底部消息推送入口 -->
  <footer-link />

  <!-- 底部安全区 -->
  <view class="safe-bottom"></view>
</view>
