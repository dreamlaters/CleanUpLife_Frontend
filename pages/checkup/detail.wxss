/**
 * 体检详情页样式
 */

.container {
  padding: 20rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
}

/* 加载状态已提取到 loading-state 组件 */

/* 头部卡片 */
.detail-header-card {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.3);
}

.detail-header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.detail-owner {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.detail-owner-emoji {
  font-size: 40rpx;
}

.detail-owner-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.detail-date {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.15);
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
}

.detail-hospital {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 20rpx;
}

.hospital-icon {
  font-size: 24rpx;
}

.detail-stats-row {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}

.detail-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 14rpx;
  min-width: 100rpx;
}

.detail-stat-num {
  font-size: 36rpx;
  font-weight: 700;
}

.detail-stat-num.total {
  color: #fff;
}

.detail-stat-num.abnormal {
  color: #fbbf24;
}

.detail-stat-num.normal {
  color: #a7f3d0;
}

.detail-stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

/* 分类区域 */
.category-section {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.category-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: #fafbfc;
  border-bottom: 1rpx solid #f3f4f6;
}

.category-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.category-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.category-abnormal-badge {
  background: #fef3c7;
  color: #92400e;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.category-normal-tag {
  background: #ecfdf5;
  color: #065f46;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.category-arrow {
  font-size: 36rpx;
  color: #9ca3af;
  transition: transform 0.2s;
  transform: rotate(0deg);
}

.category-arrow.expanded {
  transform: rotate(90deg);
}

/* 检查项 */
.category-items {
  padding: 0 16rpx;
}

.checkup-item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 12rpx;
  border-bottom: 1rpx solid #f9fafb;
}

.checkup-item-row:last-child {
  border-bottom: none;
}

.checkup-item-row.item-abnormal {
  background: #fffbeb;
}

.item-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.item-name {
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
}

.item-reference {
  font-size: 22rpx;
  color: #9ca3af;
}

.item-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.item-value-wrap {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.item-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.item-value.value-abnormal {
  color: #dc2626;
}

.item-unit {
  font-size: 22rpx;
  color: #9ca3af;
}

.item-status-badge {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  white-space: nowrap;
}

.item-status-badge.status-Normal {
  background: #ecfdf5;
  color: #065f46;
}

.item-status-badge.status-High {
  background: #fef2f2;
  color: #991b1b;
}

.item-status-badge.status-Low {
  background: #eff6ff;
  color: #1e40af;
}

.item-status-badge.status-Abnormal {
  background: #fef3c7;
  color: #92400e;
}

/* 备注 */
.detail-notes {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.notes-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  display: block;
  margin-bottom: 12rpx;
}

.notes-content {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
}

/* 操作按钮 */
.detail-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-bottom: 20rpx;
}

.action-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  line-height: 1;
}

.action-btn::after {
  border: none;
}

.edit-btn {
  background: #f0f0ff;
  color: #6366f1;
}

.delete-btn {
  background: #fef2f2;
  color: #ef4444;
}
