/* 自定义导航栏组件样式 */
.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  box-shadow: 0 4rpx 20rpx rgba(99, 102, 241, 0.25);
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  padding: 0 28rpx;
}

.navbar-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 0.5rpx;
}

.navbar-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  width: 100%;
}

.greeting {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.5rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.date-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 400;
}

.navbar-placeholder {
  width: 100%;
  flex-shrink: 0;
}
